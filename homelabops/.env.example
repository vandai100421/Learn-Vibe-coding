# HomelabOps — biến môi trường
# Copy file này thành .env và sửa giá trị (không commit .env)

# Timezone cho toàn bộ container
TZ=Asia/Ho_Chi_Minh

# Domain ảo (cần thêm vào file hosts)
# Trong Tuần 1: app1.local → Homepage, npm.local → NPM admin panel
DOMAIN_HOMEPAGE=app1.local
DOMAIN_NPM=npm.local
