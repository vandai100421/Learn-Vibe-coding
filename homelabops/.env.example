# HomelabOps — biến môi trường
# Copy file này thành .env và sửa giá trị (không commit .env)

# Timezone cho toàn bộ container
TZ=Asia/Ho_Chi_Minh

# Domain ảo (cần thêm vào file hosts)
# Tuần 1: app1.local → Homepage, npm.local → NPM admin panel
# Tuần 2: grafana.local → Grafana, prometheus.local → Prometheus
DOMAIN_HOMEPAGE=app1.local
DOMAIN_NPM=npm.local
DOMAIN_GRAFANA=grafana.local
DOMAIN_PROMETHEUS=prometheus.local

# Grafana admin — đổi password mạnh hơn khi dùng thực tế
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
