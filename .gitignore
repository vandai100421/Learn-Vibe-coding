# =====================
# Secret / env (KHÔNG commit)
# =====================
.env
.env*.local
.env.*.local
*.pem
*.key

# =====================
# HomelabOps (Project 1)
# =====================
# Backup data — có thể lớn, không commit
homelabops/backups/
homelabops/**/backups/

# Log file
*.log
homelabops/logs/

# Grafana data (chạy trong volume, không bind)
homelabops/grafana/data/

# Prometheus data
homelabops/prometheus/data/

# Loki data
homelabops/loki/data/

# Uptime Kuma data
homelabops/uptime-kuma/data/

# =====================
# OpsBrain (Project 2)
# =====================
# Ollama models — rất lớn (GB)
ollama/models/
opsbrain/ollama/models/
~/.ollama/models/

# Vector DB data
chromadb/data/
opsbrain/open-webui/data/
opsbrain/**/chroma/

# Knowledge source (tài liệu gốc, có thể lớn)
opsbrain/knowledge/

# Python virtualenv
__pycache__/
*.pyc
.venv/
venv/
env/

# =====================
# Docker
# =====================
# Không commit container export
*.tar

# =====================
# OS / editor
# =====================
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo

# =====================
# Database
# =====================
*.db
*.db-journal
*.sqlite
*.sqlite3

# =====================
# Keep these (đừng ignore)
# =====================
!.env.example
!.gitkeep
